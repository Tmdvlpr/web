# Generate a fresh Ed25519 keypair (one-time setup):
#   python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; from cryptography.hazmat.primitives.serialization import Encoding, PrivateFormat, PublicFormat, NoEncryption; pk=Ed25519PrivateKey.generate(); print(pk.private_bytes(Encoding.PEM, PrivateFormat.PKCS8, NoEncryption()).decode()); print(pk.public_key().public_bytes(Encoding.PEM, PublicFormat.SubjectPublicKeyInfo).decode())"
# Paste the output below as a single line with \n escapes inside double quotes.
PASETO_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PASETO_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
TOKEN_EXPIRE_DAYS=7
