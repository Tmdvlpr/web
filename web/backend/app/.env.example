DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@db:5432/DBNAME
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Generate fresh Ed25519 keypair: see comment in .env
PASETO_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PASETO_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost
APP_TIMEZONE=Asia/Yekaterinburg

BOT_SECRET=generate-strong-random-secret
TG_GROUP_CHAT_ID=0
INTERNAL_API_URL=http://backend:8001
TG_BOT_USERNAME=your_bot_username

CORPMEET_DEV=false

# === Video service (LiveKit) ===
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret_at_least_32_chars_xxxxxxxxx
LIVEKIT_HOST=ws://livekit:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
VIDEO_ENABLED=true
VIDEO_MAX_PARTICIPANTS=50
VIDEO_RECORDING_ENABLED=true
CHAT_FILES_PATH=/app/data/chat-files
RECORDINGS_PATH=/app/data/recordings