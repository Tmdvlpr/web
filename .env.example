# ============================================================
# CorpMeet — шаблон конфига
# Скопируй в .env и заполни значениями
# ============================================================

# ── Docker Compose ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=tg3meet
PGDATA_PATH=./pgdata

# ── База данных ───────────────────────────────────────────────
POSTGRES_USER=corpmeet
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=corpmeet
# Локально: указывай на свой сервер. В Docker переопределяется автоматически.
DATABASE_URL=postgresql+asyncpg://corpmeet:your_postgres_password@host:5432/corpmeet
DB_SCHEMA=public

# ── Бэкенд ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
APP_TIMEZONE=Asia/Yekaterinburg
TOKEN_EXPIRE_DAYS=7
CORPMEET_DEV=false
INTERNAL_API_URL=http://127.0.0.1:8001

# ── Auth (PASETO Ed25519) ─────────────────────────────────────
# Сгенерировать: python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; ..."
PASETO_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PASETO_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
BOT_SECRET=generate_strong_random_secret_min_32_chars
TG_GROUP_CHAT_ID=0
TG_BOT_USERNAME=your_bot_username

# ── LiveKit ───────────────────────────────────────────────────
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret_at_least_32_chars
LIVEKIT_HOST=ws://livekit:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
VIDEO_ENABLED=true
VIDEO_RECORDING_ENABLED=true
CHAT_FILES_PATH=/app/data/chat-files
RECORDINGS_PATH=/app/data/recordings

# ── Фронтенд (Docker build arg) ───────────────────────────────
# Пустая строка = nginx проксирует /api/ на бэкенд (рекомендуется для Docker)
# Для локального Vite — см. web/frontend/.env.local
VITE_API_URL=
